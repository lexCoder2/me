---
---

<section class="section" id="about">
  <div class="container">
    <span class="section-label">About me</span>
    <h2 class="section-title">A bit of background</h2>
    <div class="about-layout">

      <!-- LEFT: profile illustration -->
      <div class="about-illo-wrap fade-up" style="animation-delay: 80ms" aria-hidden="true">
        <svg class="about-illo" viewBox="0 0 260 290" xmlns="http://www.w3.org/2000/svg" fill="none">

          <!-- ── Background nodes ──────────────────────────── -->
          <circle cx="252" cy="14"  r="2.5" class="nd"/>
          <circle cx="258" cy="72"  r="2"   class="nd"/>
          <circle cx="254" cy="244" r="2.5" class="nd"/>
          <circle cx="6"   cy="30"  r="2"   class="nd"/>
          <circle cx="8"   cy="200" r="2.5" class="nd"/>
          <line x1="252" y1="14"  x2="258" y2="72"  class="nl"/>
          <line x1="258" y1="72"  x2="254" y2="244" class="nl"/>
          <line x1="6"   y1="30"  x2="8"   y2="200" class="nl"/>

          <!-- ── Floating => — left ───────────────────────── -->
          <g class="fa">
            <line x1="2"  y1="56" x2="13" y2="56" class="br"/>
            <polyline points="9,50 15,56 9,62"   class="br"/>
          </g>

          <!-- ── Floating [ ] — bottom right ─────────────── -->
          <g class="fb">
            <polyline points="244,248 240,248 240,268 244,268" class="br"/>
            <polyline points="250,248 254,248 254,268 250,268" class="br"/>
          </g>

          <!-- ── Card frame ─────────────────────────────────── -->
          <rect x="18" y="14" width="224" height="270" rx="12" class="card"/>

          <!-- ── Card header ────────────────────────────────── -->
          <path d="M30,14 L230,14 C236.627,14 242,19.373 242,26 L242,90 L18,90 L18,26 C18,19.373 23.373,14 30,14 Z" class="card-hd"/>

          <!-- Avatar -->
          <circle cx="52" cy="56" r="22" class="av-ring"/>
          <circle cx="52" cy="56" r="20" class="av-bg"/>
          <circle cx="52" cy="49" r="8"  class="av-head"/>
          <rect   x="42" y="58" width="20" height="12" rx="6" class="av-body"/>

          <!-- Name / role / location -->
          <rect x="86" y="42" width="76" height="8"  rx="2" class="nm"/>
          <rect x="86" y="56" width="56" height="6"  rx="2" class="rl"/>
          <!-- Location dot + bar -->
          <circle cx="90" cy="71" r="3"              class="loc-dot"/>
          <rect   x="97" y="69" width="42" height="4" rx="1" class="rl"/>
          <!-- Online status pill -->
          <rect   x="86" y="79" width="54" height="10" rx="5" class="online-pill"/>
          <circle cx="94" cy="84" r="3"               class="online-dot"/>
          <rect   x="100" y="81" width="32" height="4" rx="1" class="rl"/>

          <!-- ── Divider ───────────────────────────────────── -->
          <line x1="18" y1="90" x2="242" y2="90" class="div-line"/>

          <!-- ── Contribution graph ────────────────────────── -->
          <rect x="26" y="98" width="34" height="4" rx="1" class="sec-lbl"/>
          <!-- row 0 -->
          <rect x="26"  y="108" width="11" height="11" rx="2" class="cg-0"/>
          <rect x="40"  y="108" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="54"  y="108" width="11" height="11" rx="2" class="cg-0"/>
          <rect x="68"  y="108" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="82"  y="108" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="96"  y="108" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="110" y="108" width="11" height="11" rx="2" class="cg-0"/>
          <rect x="124" y="108" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="138" y="108" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="152" y="108" width="11" height="11" rx="2" class="cg-0"/>
          <!-- row 1 -->
          <rect x="26"  y="122" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="40"  y="122" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="54"  y="122" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="68"  y="122" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="82"  y="122" width="11" height="11" rx="2" class="cg-4"/>
          <rect x="96"  y="122" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="110" y="122" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="124" y="122" width="11" height="11" rx="2" class="cg-4"/>
          <rect x="138" y="122" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="152" y="122" width="11" height="11" rx="2" class="cg-2"/>
          <!-- row 2 -->
          <rect x="26"  y="136" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="40"  y="136" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="54"  y="136" width="11" height="11" rx="2" class="cg-4"/>
          <rect x="68"  y="136" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="82"  y="136" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="96"  y="136" width="11" height="11" rx="2" class="cg-4"/>
          <rect x="110" y="136" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="124" y="136" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="138" y="136" width="11" height="11" rx="2" class="cg-4"/>
          <rect x="152" y="136" width="11" height="11" rx="2" class="cg-3"/>
          <!-- row 3 -->
          <rect x="26"  y="150" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="40"  y="150" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="54"  y="150" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="68"  y="150" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="82"  y="150" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="96"  y="150" width="11" height="11" rx="2" class="cg-4"/>
          <rect x="110" y="150" width="11" height="11" rx="2" class="cg-3"/>
          <rect x="124" y="150" width="11" height="11" rx="2" class="cg-1"/>
          <rect x="138" y="150" width="11" height="11" rx="2" class="cg-2"/>
          <rect x="152" y="150" width="11" height="11" rx="2" class="cg-4"/>
          <!-- Month label bars -->
          <rect x="26"  y="168" width="22" height="4" rx="1" class="sec-lbl"/>
          <rect x="68"  y="168" width="22" height="4" rx="1" class="sec-lbl"/>
          <rect x="110" y="168" width="22" height="4" rx="1" class="sec-lbl"/>

          <!-- ── Divider ───────────────────────────────────── -->
          <line x1="18" y1="182" x2="242" y2="182" class="div-line"/>

          <!-- ── Tech stack ─────────────────────────────────── -->
          <rect x="26" y="190" width="28" height="4" rx="1" class="sec-lbl"/>
          <!-- row 1: React · Node.js · TypeScript -->
          <rect x="26"  y="200" width="38" height="14" rx="7" class="tag-a"/>
          <rect x="30"  y="205" width="30" height="4"  rx="1" class="tag-text"/>
          <rect x="70"  y="200" width="46" height="14" rx="7" class="tag-a"/>
          <rect x="74"  y="205" width="38" height="4"  rx="1" class="tag-text"/>
          <rect x="122" y="200" width="56" height="14" rx="7" class="tag-b"/>
          <rect x="126" y="205" width="48" height="4"  rx="1" class="tag-text"/>
          <!-- row 2: Python · AWS · Azure · GCP -->
          <rect x="26"  y="220" width="42" height="14" rx="7" class="tag-b"/>
          <rect x="30"  y="225" width="34" height="4"  rx="1" class="tag-text"/>
          <rect x="74"  y="220" width="30" height="14" rx="7" class="tag-c"/>
          <rect x="78"  y="225" width="22" height="4"  rx="1" class="tag-text"/>
          <rect x="110" y="220" width="32" height="14" rx="7" class="tag-c"/>
          <rect x="114" y="225" width="24" height="4"  rx="1" class="tag-text"/>
          <rect x="148" y="220" width="28" height="14" rx="7" class="tag-c"/>
          <rect x="152" y="225" width="20" height="4"  rx="1" class="tag-text"/>
          <!-- row 3: Docker · LLMs · MCP · AI -->
          <rect x="26"  y="240" width="38" height="14" rx="7" class="tag-c"/>
          <rect x="30"  y="245" width="30" height="4"  rx="1" class="tag-text"/>
          <rect x="70"  y="240" width="30" height="14" rx="7" class="tag-b"/>
          <rect x="74"  y="245" width="22" height="4"  rx="1" class="tag-text"/>
          <rect x="106" y="240" width="22" height="14" rx="7" class="tag-b"/>
          <rect x="110" y="245" width="14" height="4"  rx="1" class="tag-text"/>
          <rect x="134" y="240" width="26" height="14" rx="7" class="tag-a"/>
          <rect x="138" y="245" width="18" height="4"  rx="1" class="tag-text"/>

          <!-- ── Status bar ──────────────────────────────────── -->
          <path d="M18,262 L242,262 L242,274 C242,280.627 236.627,284 230,284 L30,284 C23.373,284 18,280.627 18,274 Z" class="card-stat"/>
          <rect x="26"  y="267" width="6"  height="5" rx="1" class="sl"/>
          <rect x="36"  y="267" width="22" height="5" rx="1" class="sl"/>
          <rect x="172" y="267" width="26" height="5" rx="1" class="sr"/>
          <rect x="204" y="267" width="16" height="5" rx="1" class="sr"/>
          <rect x="226" y="267" width="10" height="5" rx="1" class="sr"/>
        </svg>
      </div>

      <!-- RIGHT: text content -->
      <div class="about-body fade-up" style="animation-delay: 0ms">
        <p>
          Senior Full-Stack Engineer with 10+ years building scalable web applications, REST APIs, and
        cloud-native systems across fintech, healthcare, and enterprise sectors. Using
        <strong>React</strong>, <strong>Angular</strong>, <strong>Node.js</strong>, and
        <strong>Python</strong>, I've worked across the full stack — from database design to cloud
        infrastructure on <strong>Azure</strong> and <strong>AWS</strong>.
      </p>
      <p>
        In recent years I've become an expert in generative AI: designing secure, production-ready
        LLM workflows, building MCP servers, and orchestrating multi-agent systems. I care a lot
        about code quality, security, and delivering things that actually work in the real world.
      </p>
      <p>
        I thrive in cross-functional teams, value clear communication, and care deeply about
        security, code quality, and delivering software that genuinely works at scale.
      </p>
      <ul class="meta-list">
        <li>
          <span class="meta-label">Location</span>
          <span class="meta-value">Cuauhtémoc, Mexico City, MX</span>
        </li>
        <li>
          <span class="meta-label">Email</span>
          <a href="mailto:hi@iarodriguez.com" class="meta-value">hi@iarodriguez.com</a>
        </li>
        <li>
          <span class="meta-label">Education</span>
          <span class="meta-value">Software Engineering — IPN, ESIME</span>
        </li>
      </ul>
      </div><!-- .about-body -->
    </div><!-- .about-layout -->
  </div>
</section>

<style>
  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .about-body p {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--leading-loose);
    max-width: 640px;
  }

  .about-body strong {
    color: var(--text);
    font-weight: var(--weight-semibold);
  }

  .meta-list {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meta-list li {
    display: flex;
    gap: var(--space-6);
    align-items: baseline;
  }

  .meta-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
    min-width: 80px;
  }

  .meta-value {
    font-size: var(--text-sm);
    color: var(--text-muted);
    transition: color var(--t-base);
  }

  a.meta-value:hover {
    color: var(--accent);
  }

  /* ── Two-column layout ───────────────────────────────────── */
  .about-layout {
    display: flex;
    align-items: flex-start;
    gap: var(--space-20);
  }

  .about-body {
    flex: 1 1 0;
    min-width: 0;
  }

  .about-illo-wrap {
    flex-shrink: 0;
    width: clamp(200px, 26vw, 280px);
  }

  .about-illo {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* ── Illustration: node graph ────────────────────────────── */
  .nd  { fill: var(--accent); opacity: 0.25; }
  .nl  { stroke: var(--accent); stroke-width: 0.8; opacity: 0.12; }
  .br  { stroke: var(--accent); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; opacity: 0.55; }

  .fa { animation: fa 5s ease-in-out infinite; }
  .fb { animation: fb 6.5s ease-in-out infinite; }
  @keyframes fa { 0%, 100% { transform: translateY(0);    } 50% { transform: translateY(-6px); } }
  @keyframes fb { 0%, 100% { transform: translateY(0);    } 50% { transform: translateY(5px);  } }

  /* ── Illustration: card ──────────────────────────────────── */
  .card    { stroke: var(--border); stroke-width: 1.5; }
  .card-hd { fill: var(--bg-alt); }

  /* Avatar */
  .av-ring { stroke: var(--accent); stroke-width: 1.5; opacity: 0.6; }
  .av-bg   { fill: var(--bg); }
  .av-head { fill: var(--accent); opacity: 0.5; }
  .av-body { fill: var(--accent); opacity: 0.28; }

  /* Name / role bars */
  .nm       { fill: var(--text-muted); opacity: 0.4; }
  .rl       { fill: var(--text-faint); opacity: 0.22; }
  .loc-dot  { fill: #3cba6c; opacity: 0.75; }
  .online-pill { fill: rgba(60,186,108,0.08); stroke: rgba(60,186,108,0.28); stroke-width: 1; }
  .online-dot  { fill: #3cba6c; opacity: 0.85; }

  .div-line { stroke: var(--border); stroke-width: 1; opacity: 0.5; }
  .sec-lbl  { fill: var(--text-faint); opacity: 0.18; }

  /* Contribution grid */
  .cg-0 { fill: var(--bg-alt); opacity: 0.6; }
  .cg-1 { fill: #3cba6c; opacity: 0.18; }
  .cg-2 { fill: #3cba6c; opacity: 0.35; }
  .cg-3 { fill: #3cba6c; opacity: 0.6;  }
  .cg-4 { fill: #3cba6c; opacity: 0.9;  }

  /* Skill tags */
  .tag-a    { fill: var(--accent-dim); stroke: var(--accent); stroke-width: 1; opacity: 0.85; }
  .tag-b    { fill: rgba(60,186,108,0.1); stroke: rgba(60,186,108,0.3); stroke-width: 1; }
  .tag-c    { fill: var(--bg-alt); stroke: var(--border); stroke-width: 1; }
  .tag-text { fill: var(--text-faint); opacity: 0.28; }

  /* Status bar */
  .card-stat { fill: var(--accent); opacity: 0.14; }
  .sl { fill: #fff; opacity: 0.5; }
  .sr { fill: #fff; opacity: 0.35; }

  @media (max-width: 900px) {
    .about-layout {
      flex-direction: column-reverse;
    }
    .about-illo-wrap {
      width: clamp(180px, 60vw, 260px);
      align-self: center;
    }
  }
</style>
