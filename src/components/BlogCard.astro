---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="blog-card">
  <a href={`/blog/${post.id}`} class="card-link" tabindex="-1" aria-hidden="true"></a>

  <header class="card-header">
    <time class="card-date" datetime={date.toISOString()}>{formattedDate}</time>
    {tags && tags.length > 0 && (
      <ul class="card-tags">
        {tags.slice(0, 3).map((tag: string) => (
          <li class="card-tag">{tag}</li>
        ))}
      </ul>
    )}
  </header>

  <h2 class="card-title">
    <a href={`/blog/${post.id}`}>{title}</a>
  </h2>

  {description && <p class="card-desc">{description}</p>}

  <a href={`/blog/${post.id}`} class="card-read">
    Read post <span aria-hidden="true">→</span>
  </a>
</article>

<style>
  .blog-card {
    position: relative;
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--border);
    transition: opacity var(--t-base);
  }

  .blog-card:last-child {
    border-bottom: none;
  }

  /* Invisible full-card click target, sits behind text links */
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
    position: relative;
    z-index: 1;
  }

  .card-date {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-faint);
    letter-spacing: var(--tracking-wide);
  }

  .card-tags {
    display: flex;
    gap: var(--space-2);
  }

  .card-tag {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--accent);
    letter-spacing: var(--tracking-wide);
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-3);
    position: relative;
    z-index: 1;
  }

  .card-title a {
    color: var(--text);
    transition: color var(--t-base);
  }

  .card-title a:hover {
    color: var(--accent);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-loose);
    max-width: 560px;
    margin-bottom: var(--space-4);
    position: relative;
    z-index: 1;
  }

  .card-read {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-faint);
    display: inline-flex;
    gap: var(--space-2);
    position: relative;
    z-index: 1;
    transition: color var(--t-base), gap var(--t-base);
  }

  .card-read:hover {
    color: var(--accent);
    gap: var(--space-3);
  }
</style>
