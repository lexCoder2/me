---
// Interactive dot-grid canvas background.
// All animation logic lives in src/scripts/canvas.ts
---

<canvas id="bg-canvas" aria-hidden="true"></canvas>

<script>
  import { initCanvas } from '../scripts/canvas';
  initCanvas();
</script>

<style>
  #bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  /* Everything above the canvas */
  :global(main),
  :global(nav) {
    position: relative;
    z-index: 1;
  }
</style>
