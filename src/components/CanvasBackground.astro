---
// All effect parameters — edit these to tune the animation
// ─────────────────────────────────────────────────────────────
// GRID_SIZE        : pixels between each dot
// DOT_RADIUS       : base dot radius in px
// DOT_COLOR        : RGBA fill of each dot at rest
// INFLUENCE_RADIUS : cursor repulsion / displacement range (px)
// GLOW_RADIUS      : illumination range — must be > INFLUENCE_RADIUS
// REPULSION_FORCE  : how strongly dots flee the cursor (0–1)
// RETURN_SPEED     : how quickly dots return to rest (0–1, lower = slower)
// MAX_GLOW_BLUR    : peak canvas shadowBlur for the nearest glowing dots
---

<canvas id="bg-canvas" aria-hidden="true"></canvas>

<script>
  // ─── Parameters ───────────────────────────────────────────
  const GRID_SIZE        = 42;
  const DOT_RADIUS       = 1.3;
  const DOT_COLOR        = 'rgba(108, 126, 255, 0.18)';
  const INFLUENCE_RADIUS = 140;   // repulsion / displacement range
  const GLOW_RADIUS      = 260;   // illumination range  (larger than repulsion)
  const REPULSION_FORCE  = 0.22;
  const RETURN_SPEED     = 0.1;
  const MAX_GLOW_BLUR    = 10;    // peak shadowBlur for the nearest dots

  // ─── State ────────────────────────────────────────────────
  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  interface Dot {
    bx: number; by: number;   // base position
    cx: number; cy: number;   // current position
  }

  let dots: Dot[] = [];
  let mouse = { x: -9999, y: -9999 };
  let rafId: number;

  // ─── Helpers ──────────────────────────────────────────────
  // Smoothstep — S-curve ease in/out, t in [0,1]
  function smoothstep(t: number): number {
    return t * t * (3 - 2 * t);
  }

  // Interpolate base blue → bright near-white based on ease value
  // base: rgb(108,126,255) @0.18  →  bright: rgb(215,220,255) @1.0
  function glowColor(ease: number): string {
    const r = Math.round(108 + ease * (215 - 108));
    const g = Math.round(126 + ease * (220 - 126));
    const b = 255;
    const a = +(0.18 + ease * (1.0 - 0.18)).toFixed(3);
    return `rgba(${r},${g},${b},${a})`;
  }

  // ─── Build grid ───────────────────────────────────────────
  function buildGrid() {
    dots = [];
    const cols = Math.ceil(canvas.width  / GRID_SIZE) + 1;
    const rows = Math.ceil(canvas.height / GRID_SIZE) + 1;
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const bx = c * GRID_SIZE;
        const by = r * GRID_SIZE;
        dots.push({ bx, by, cx: bx, cy: by });
      }
    }
  }

  // ─── Resize ───────────────────────────────────────────────
  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    buildGrid();
  }

  // ─── Draw ─────────────────────────────────────────────────
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const dot of dots) {
      const dx   = dot.bx - mouse.x;
      const dy   = dot.by - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      // ── Repulsion spring ──────────────────────────────────
      if (dist < INFLUENCE_RADIUS) {
        const force = (1 - dist / INFLUENCE_RADIUS) * REPULSION_FORCE;
        const angle = Math.atan2(dy, dx);
        dot.cx += (dot.bx + Math.cos(angle) * force * INFLUENCE_RADIUS - dot.cx) * RETURN_SPEED * 2;
        dot.cy += (dot.by + Math.sin(angle) * force * INFLUENCE_RADIUS - dot.cy) * RETURN_SPEED * 2;
      } else {
        dot.cx += (dot.bx - dot.cx) * RETURN_SPEED;
        dot.cy += (dot.by - dot.cy) * RETURN_SPEED;
      }

      // ── Radial glow  (GLOW_RADIUS > INFLUENCE_RADIUS) ─────
      if (dist < GLOW_RADIUS) {
        const tRaw  = 1 - dist / GLOW_RADIUS;     // linear  [0 → 1]
        const tEase = smoothstep(tRaw);            // eased   [0 → 1]

        ctx.shadowColor = 'rgba(200, 210, 255, 0.85)';
        ctx.shadowBlur  = tEase * MAX_GLOW_BLUR;
        ctx.fillStyle   = glowColor(tEase);
        ctx.globalAlpha = 1;
      } else {
        ctx.shadowBlur  = 0;
        ctx.fillStyle   = DOT_COLOR;
        ctx.globalAlpha = 1;
      }

      ctx.beginPath();
      ctx.arc(dot.cx, dot.cy, DOT_RADIUS, 0, Math.PI * 2);
      ctx.fill();
    }

    // Reset shadow so it never bleeds into other draw calls
    ctx.shadowBlur  = 0;
    ctx.globalAlpha = 1;
    rafId = requestAnimationFrame(draw);
  }

  // ─── Mouse tracking ───────────────────────────────────────
  window.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  window.addEventListener('mouseleave', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });

  // Touch support
  window.addEventListener('touchmove', (e) => {
    const t = e.touches[0];
    mouse.x = t.clientX;
    mouse.y = t.clientY;
  }, { passive: true });

  window.addEventListener('touchend', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });

  // ─── Init ─────────────────────────────────────────────────
  const ro = new ResizeObserver(resize);
  ro.observe(document.documentElement);

  resize();
  draw();
</script>

<style>
  #bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  /* Everything above the canvas */
  :global(main),
  :global(nav) {
    position: relative;
    z-index: 1;
  }
</style>
