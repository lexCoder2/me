---
const contactItems = [
  {
    label: 'Email',
    value: 'hi@iarodriguez.com',
    href: 'mailto:hi@iarodriguez.com',
  },
  {
    label: 'Phone',
    value: '+52 55669 46649',
    href: 'tel:+525566946649',
  },
  {
    label: 'GitHub',
    value: 'lexCoder2',
    href: 'https://github.com/lexCoder2',
  },
  {
    label: 'LinkedIn',
    value: 'in/iarodriguezr',
    href: 'https://linkedin.com/in/iarodriguezr',
  },
  {
    label: 'Location',
    value: 'Cuauhtémoc, Mexico City, MX',
    href: null,
  },
];
---

<section class="section" id="contact">
  <div class="container">
    <span class="section-label">Let's talk</span>
    <h2 class="section-title">Get in touch</h2>
    <p class="contact-intro">
      Open to new opportunities, collaborations, and interesting conversations.
      The best way to reach me is by email — I'll get back to you promptly.
    </p>

    <ul class="contact-list">
      {contactItems.map((item) => (
        <li class="contact-item">
          <span class="contact-label">{item.label}</span>
          {item.href ? (
            <a href={item.href} class="contact-value contact-link"
               {...(item.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {item.value}
            </a>
          ) : (
            <span class="contact-value">{item.value}</span>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .contact-intro {
    font-size: var(--text-base);
    color: var(--text-muted);
    max-width: 520px;
    line-height: var(--leading-loose);
    margin-bottom: var(--space-10);
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-item {
    display: flex;
    gap: var(--space-8);
    align-items: baseline;
  }

  .contact-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
    min-width: 72px;
  }

  .contact-value {
    font-size: var(--text-sm);
    color: var(--text-muted);
    transition: color var(--t-base);
  }

  .contact-link:hover {
    color: var(--accent);
  }
</style>
