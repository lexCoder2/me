---
import { useTranslations } from '../i18n';
const T = useTranslations(Astro.currentLocale);

const contactItems = [
  {
    labelKey: 'email' as const,
    value: 'hi@iarodriguez.com',
    href: 'mailto:hi@iarodriguez.com',
  },
  {
    labelKey: 'phone' as const,
    value: '+52 55669 46649',
    href: 'tel:+525566946649',
  },
  {
    labelKey: 'github' as const,
    value: 'lexCoder2',
    href: 'https://github.com/lexCoder2',
  },
  {
    labelKey: 'linkedin' as const,
    value: 'in/iarodriguezr',
    href: 'https://linkedin.com/in/iarodriguezr',
  },
  {
    labelKey: 'location' as const,
    value: 'Cuauhtémoc, Mexico City, MX',
    href: null,
  },
];
---

<section class="section" id="contact">
  <div class="container">
    <span class="section-label">{T.contact.label}</span>
    <h2 class="section-title">{T.contact.title}</h2>
    <p class="contact-intro">
      {T.contact.intro}
    </p>

    <div class="contact-body">
      <!-- Contact form -->
      <form
        class="contact-form"
        action="https://formsubmit.co/hi@iarodriguez.com"
        method="POST"
      >
        <!-- formsubmit.co config -->
        <input type="hidden" name="_subject" value="New message from iarodriguez.com" />
        <input type="hidden" name="_next" value="https://iarodriguez.com/#contact" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_honey" style="display:none" />

        <div class="form-row">
          <div class="form-group">
            <label for="contact-name" class="form-label">{T.contact.form.name}</label>
            <input
              id="contact-name"
              type="text"
              name="name"
              class="form-input"
              placeholder={T.contact.form.namePlaceholder}
              required
            />
          </div>
          <div class="form-group">
            <label for="contact-email" class="form-label">{T.contact.form.email}</label>
            <input
              id="contact-email"
              type="email"
              name="email"
              class="form-input"
              placeholder={T.contact.form.emailPlaceholder}
              required
            />
          </div>
        </div>

        <div class="form-group">
          <label for="contact-message" class="form-label">{T.contact.form.message}</label>
          <textarea
            id="contact-message"
            name="message"
            class="form-input form-textarea"
            placeholder={T.contact.form.messagePlaceholder}
            rows="5"
            required
          ></textarea>
        </div>

        <button type="submit" class="form-submit">{T.contact.form.submit}</button>
      </form>

      <!-- Contact info sidebar -->
      <ul class="contact-list">
        {contactItems.map((item) => (
          <li class="contact-item">
            <span class="contact-label">{T.contact.items[item.labelKey]}</span>
            {item.href ? (
              <a href={item.href} class="contact-value contact-link"
                 {...(item.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {item.value}
              </a>
            ) : (
              <span class="contact-value">{item.value}</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .contact-intro {
    font-size: var(--text-base);
    color: var(--text-muted);
    max-width: 520px;
    line-height: var(--leading-loose);
    margin-bottom: var(--space-10);
  }

  .contact-body {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 640px) {
    .contact-body {
      grid-template-columns: 1fr;
    }
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .form-input {
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--text-faint) 30%, transparent);
    border-radius: var(--radius-sm, 6px);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    color: var(--text-body);
    transition: border-color var(--t-base), box-shadow var(--t-base);
    width: 100%;
    outline: none;
  }

  .form-input::placeholder {
    color: var(--text-faint);
  }

  .form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    padding: 0.65em 1.5em;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    background: var(--accent);
    color: #fff;
    transition: background var(--t-base), transform var(--t-fast);
  }

  .form-submit:hover  { background: var(--accent-hover); transform: translateY(-1px); }
  .form-submit:active { transform: translateY(0); }

  /* ── Contact list sidebar ── */
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-2);
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .contact-value {
    font-size: var(--text-sm);
    color: var(--text-muted);
    transition: color var(--t-base);
  }

  .contact-link:hover {
    color: var(--accent);
  }
</style>
