---
const jobs = [
  {
    company: 'Kunai–PwC',
    role: 'Senior Associate',
    period: '2024 – 2026',
    highlights: [
      'Senior engineer on secure, highly regulated projects for financial institutions, leading cross-functional teams to deliver high-quality software.',
      'Integrated AI-powered workflows and automations into internal tooling, reducing manual processes.',
    ],
    projects: [
      {
        name: 'Capital One',
        desc: 'Led development of an internal platform to automate security compliance and software delivery across the engineering organization, reducing manual review cycles and improving deployment standards.',
      },
      {
        name: 'PwC',
        desc: 'Principal architect of an AI-powered research and portfolio automation system; implemented RAG pipelines and LLM-driven agents to generate data-driven client analysis reports.',
      },
    ],
  },
  {
    company: 'Wizeline',
    role: 'Senior Software Engineer',
    period: '2020 – 2023',
    highlights: [
      'Worked on multiple projects for clients in North America as developer and consultant, delivering full-stack solutions and architectural improvements across cloud and mobile platforms.',
    ],
    projects: [
      { name: 'Google', desc: 'Developed and optimized distributed data processing pipelines in Python and Java using Apache Beam on Google Cloud Dataflow, handling large-scale event streams.' },
      { name: 'Grupo Salinas', desc: 'Built full-stack features for a high-traffic fintech super-app (BAZ) using React and Node.js, serving millions of users across Mexico.' },
      { name: 'American Water Resources', desc: 'Designed and implemented a scalable plan-selling system with Angular and Node.js, integrating third-party payment and CRM APIs.' },
    ],
  },
  {
    company: 'Purpura Analytics',
    role: 'Senior Full-Stack Developer',
    period: '2018 – 2020',
    highlights: [
      'Lead developer responsible for all client projects and their architectures.',
      'Created code guidelines and led team meetings and task management.',
      'Built web apps with Angular 4+, VueJS, and mobile apps with Ionic.',
      'Designed and built REST APIs with Node.js and Laravel; database design with MongoDB and MySQL.',
    ],
    projects: [],
  },
  {
    company: 'Creatima',
    role: 'Software Developer',
    period: '2016 – 2018',
    highlights: [
      'Maintained legacy systems built with PHP Laravel and developed new SPAs.',
      'Delivered custom UI/UX websites and custom database reports per client.',
      'Built web apps with Angular 2+ and Laravel; websites with HTML5, CSS3, and JavaScript.',
    ],
    projects: [],
  },
];
---

<section class="section" id="experience">
  <div class="container">
    <span class="section-label">Work history</span>
    <h2 class="section-title">Experience</h2>

    <ol class="timeline" role="list">
      {jobs.map((job, i) => (
        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true"></div>
          <div class="timeline-content">
            <div class="job-header">
              <div class="job-info">
                <h3 class="job-company">{job.company}</h3>
                <p class="job-role">{job.role}</p>
              </div>
              <time class="job-period">{job.period}</time>
            </div>

            <ul class="highlight-list">
              {job.highlights.map((h) => (
                <li class="highlight">{h}</li>
              ))}
            </ul>

            {job.projects.length > 0 && (
              <ul class="project-list">
                {job.projects.map((p) => (
                  <li class="project-item">
                    <span class="project-name">{p.name}</span>
                    <span class="project-desc">{p.desc}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  /* ── Timeline ────────────────────────────────────────────── */
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding-left: var(--space-6);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    padding-left: var(--space-8);
  }

  .timeline-marker {
    position: absolute;
    left: calc(-1 * var(--space-6) - 3px);
    top: 6px;
    width: 7px;
    height: 7px;
    border-radius: var(--radius-full);
    background: var(--accent);
    transition: background var(--t-base), transform var(--t-base);
  }

  .timeline-item:hover .timeline-marker {
    transform: scale(1.6);
    background: var(--accent-hover);
  }

  /* ── Job header ──────────────────────────────────────────── */
  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .job-company {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--text);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-1);
  }

  .job-role {
    font-size: var(--text-sm);
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .job-period {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-faint);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
    padding-top: 3px;
  }

  /* ── Highlights ──────────────────────────────────────────── */
  .highlight-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .highlight {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-loose);
    padding-left: var(--space-4);
    position: relative;
  }

  .highlight::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--text-faint);
    font-size: var(--text-xs);
  }

  /* ── Projects ────────────────────────────────────────────── */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .project-item {
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
    font-size: var(--text-sm);
    flex-wrap: wrap;
  }

  .project-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text);
    font-weight: var(--weight-medium);
    white-space: nowrap;
  }

  .project-desc {
    color: var(--text-faint);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
  }
</style>
