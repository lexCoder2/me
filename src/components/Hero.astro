---

<section class="hero" id="home">
  <div class="container hero-layout">

    <!-- LEFT: brand lockup + text -->
    <div class="hero-text">
      <p class="hero-greeting fade-up" style="animation-delay: 0ms">Hi, I'm</p>

      <!-- logo + name side-by-side lockup -->
      <div class="brand-lockup fade-up logo-mark-wrap" style="animation-delay: 60ms" aria-label="lexCoder — Irwin Rodriguez">
        <svg
          class="logo-mark"
          viewBox="0 0 948 948"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          aria-hidden="true"
