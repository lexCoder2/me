---
import HeroLogo from './hero/HeroLogo.astro';
import HeroIllustration from './hero/HeroIllustration.astro';
---

<section class="hero" id="home">
  <div class="container hero-layout">

    <!-- LEFT: brand lockup + text -->
    <div class="hero-text">
      <div class="avail-badge fade-up" style="animation-delay: 0ms">
        <span class="avail-dot" aria-hidden="true"></span>
        Available for opportunities
      </div>

      <HeroLogo />

      <p class="hero-greeting fade-up" style="animation-delay: 130ms">Hi, I'm</p>
      <h1 class="hero-name fade-up" style="animation-delay: 190ms">
        <span>Alex </span><span class="hero-name-accent">Rodriguez</span>
      </h1>

      <h2 class="hero-title fade-up" style="animation-delay: 250ms">
        Senior Full-Stack Developer
      </h2>
      <p class="hero-tagline fade-up" style="animation-delay: 330ms">
        I build fast, secure, and thoughtful web experiences — and I love
        every layer of the stack.
      </p>

      <ul class="hero-stats fade-up" style="animation-delay: 390ms" aria-label="Career highlights">
        <li><span class="stat-num">10+</span>&nbsp;yrs</li>
        <li class="stat-sep" aria-hidden="true">/</li>
        <li>React · Node.js · Python</li>
        <li class="stat-sep" aria-hidden="true">/</li>
        <li>AWS · Azure · GCP</li>
      </ul>

      <div class="hero-actions fade-up" style="animation-delay: 450ms">
        <a href="#contact" class="btn btn-primary">Get in touch</a>
        <a href="/blog" class="btn btn-ghost">Read the blog</a>
        <a href="/Irwin Alejandro Rodriguez Ramirez - Resume.pdf" download class="btn btn-ghost">Download Resume</a>
      </div>
    </div>

    <!-- RIGHT: developer illustration -->
    <HeroIllustration />

  </div>

  <!-- Scroll hint -->
  <a href="#about" class="scroll-hint" aria-label="Scroll to about section">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    position: relative;
  }

  .hero-layout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-12);
  }

  .hero-text {
    flex: 1 1 0;
    min-width: 0;
  }

  .hero-greeting {
    font-size: var(--text-base);
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: var(--space-1);
    letter-spacing: var(--tracking-wide);
  }

  .hero-name {
    font-size: clamp(var(--text-4xl), 7vw, 5rem);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text);
    margin: 0 0 var(--space-3);
  }

  .hero-name-accent { color: var(--accent); }

  .hero-title {
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    max-width: 480px;
    color: var(--text-muted);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-5);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Stats row */
  .hero-stats {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-faint);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-8);
  }

  .stat-num {
    color: var(--accent);
    font-weight: var(--weight-semibold);
  }

  .stat-sep {
    color: var(--text-faint);
    opacity: 0.4;
    user-select: none;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    padding: 0.65em 1.5em;
    border-radius: var(--radius-sm);
    transition:
      color        var(--t-base),
      background   var(--t-base),
      border-color var(--t-base),
      opacity      var(--t-base),
      transform    var(--t-fast);
  }

  .btn:hover  { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 0 14px -6px color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
    box-shadow: 0 0 18px -4px color-mix(in srgb, var(--accent) 48%, transparent);
  }

  .btn-ghost {
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover {
    color: var(--text);
    border-color: var(--text-faint);
  }

  /* Availability badge */
  .avail-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
    color: var(--text-muted);
    background: var(--bg-alt);
    border: 1px solid var(--border);
    padding: 5px 14px;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-5);
  }

  .avail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #3cba6c;
    box-shadow: 0 0 0 0 rgba(60, 186, 108, 0.5);
    animation: pulse-dot 2.2s ease-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%   { box-shadow: 0 0 0 0   rgba(60, 186, 108, 0.5); }
    70%  { box-shadow: 0 0 0 6px rgba(60, 186, 108, 0);   }
    100% { box-shadow: 0 0 0 0   rgba(60, 186, 108, 0);   }
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-faint);
    transition: color var(--t-base);
    animation: bounce-down 2.4s ease-in-out infinite;
  }

  .scroll-hint:hover { color: var(--text-muted); }

  @keyframes bounce-down {
    0%, 100% { transform: translateX(-50%) translateY(0);   }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-height: 600px) { .scroll-hint { display: none; } }

  @media (max-width: 900px) {
    .hero-layout {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-10);
    }
  }
</style>
