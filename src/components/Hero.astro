76.833,937.152C1520.768,907.54 1461.162,893.637 1382.67,933.816C1378.841,935.776 1379.445,930.366 1379.445,930.366C1381.399,916.366 1379.483,908.308 1377.338,897.31C1376.514,893.084 1379.565,892.598 1382.545,890.943C1442.426,857.672 1534.388,865.834 1597.89,900.294C1641.177,923.784 1674.999,952.085 1692.822,980.863C1715.106,1016.842 1694.948,1054.12 1682.545,1066.265C1655.892,1092.364 1620.603,1092.205 1590.425,1065.561C1534.853,1016.497 1484.689,1005.879 1444.514,1020.38C1384.679,1041.976 1349.808,1114.981 1357.913,1177.684C1363.555,1221.34 1380.036,1252.505 1402.798,1272.759C1454.521,1318.783 1523.427,1318.135 1567.205,1282.495C1610.269,1247.436 1628.945,1244.527 1651.438,1249.237C1664.822,1252.04 1679.447,1261.521 1689.87,1278.307C1707.699,1307.019 1707.462,1345.811 1675.169,1374.956C1623.002,1422.038 1530.981,1460.745 1463.342,1455.133C1399.913,1449.87 1333.911,1415.302 1273.295,1359.556Z"
            />
          </g>
        </svg>
        <h1 class="hero-name">Alex Rodriguez</h1>
      </div>

      <h2 class="hero-title fade-up" style="animation-delay: 160ms">
        Senior Full-Stack Developer
      </h2>
      <p class="hero-tagline fade-up" style="animation-delay: 240ms">
        I build fast, secure, and thoughtful web experiences — and I love
        every layer of the stack.
      </p>
      <div class="hero-actions fade-up" style="animation-delay: 320ms">
        <a href="/me/#contact" class="btn btn-primary">Get in touch</a>
        <a href="/me/blog" class="btn btn-ghost">Read the blog</a>
        <a href="/me/Irwin Alejandro Rodriguez Ramirez - Resume.pdf" download class="btn btn-ghost">Download Resume</a>
      </div>
    </div>

    <!-- RIGHT: developer / computer illustration -->
    <div class="dev-illo-wrap fade-up" style="animation-delay: 200ms" aria-hidden="true">
      <svg class="dev-illo" viewBox="0 0 360 310" xmlns="http://www.w3.org/2000/svg" fill="none">

        <!-- ── Background node graph ─────────────────────────── -->
        <circle cx="326" cy="28"  r="3" class="nd"/>
        <circle cx="352" cy="136" r="2" class="nd"/>
        <circle cx="334" cy="266" r="3" class="nd"/>
        <circle cx="18"  cy="76"  r="2" class="nd"/>
        <circle cx="24"  cy="250" r="3" class="nd"/>
        <line x1="326" y1="28"  x2="352" y2="136" class="nl"/>
        <line x1="352" y1="136" x2="334" y2="266" class="nl"/>
        <line x1="18"  y1="76"  x2="24"  y2="250" class="nl"/>

        <!-- ── Floating </> tag — top-right ─────────────────── -->
        <g class="float-a">
          <polyline points="303,16 293,24 303,32" class="br"/>
          <line x1="309" y1="16" x2="315" y2="32" class="br"/>
          <polyline points="321,16 331,24 321,32" class="br"/>
        </g>

        <!-- ── Floating { } braces — bottom-left ────────────── -->
        <g class="float-b">
          <path d="M34,250 C30,250 31,244 31,240 C31,236 28,236 28,236 C28,236 31,236 31,232 C31,228 30,222 34,222" class="br"/>
          <path d="M42,250 C46,250 45,244 45,240 C45,236 48,236 48,236 C48,236 45,236 45,232 C45,228 46,222 42,222" class="br"/>
        </g>

        <!-- ── Terminal window ───────────────────────────────── -->
        <!-- Outer frame -->
        <rect x="56" y="42" width="260" height="198" rx="10" class="win-frame"/>
        <!-- Title bar fill -->
        <path d="M66,42 L306,42 C311.523,42 316,46.477 316,52 L316,70 L56,70 L56,52 C56,46.477 60.477,42 66,42 Z" class="win-bar"/>
        <!-- Traffic lights -->
        <circle cx="78"  cy="56" r="5" class="dot-r"/>
        <circle cx="95"  cy="56" r="5" class="dot-y"/>
        <circle cx="112" cy="56" r="5" class="dot-g"/>
        <!-- Tab pill -->
        <rect x="138" y="49" width="58" height="14" rx="4" class="tab-pill"/>

        <!-- ── Code lines ─────────────────────────────────── -->
        <!-- line 1: prompt + command -->
        <rect x="74"  y="84"  width="9"  height="7" rx="2" class="c-dim"/>
        <rect x="88"  y="84"  width="52" height="7" rx="3" class="c-accent"/>
        <rect x="146" y="84"  width="34" height="7" rx="3" class="c-muted"/>

        <!-- line 2 -->
        <rect x="86"  y="101" width="28" height="7" rx="3" class="c-accent"/>
        <rect x="120" y="101" width="7"  height="7" rx="2" class="c-dim"/>
        <rect x="133" y="101" width="48" height="7" rx="3" class="c-muted"/>
        <rect x="187" y="101" width="7"  height="7" rx="2" class="c-dim"/>

        <!-- line 3 -->
        <rect x="86"  y="118" width="22" height="7" rx="3" class="c-accent"/>
        <rect x="114" y="118" width="54" height="7" rx="3" class="c-muted"/>
        <rect x="174" y="118" width="20" height="7" rx="3" class="c-accent2"/>

        <!-- line 4 -->
        <rect x="74"  y="135" width="9"  height="7" rx="2" class="c-dim"/>
        <rect x="88"  y="135" width="40" height="7" rx="3" class="c-muted"/>

        <!-- line 5 — long accent (highlight line) -->
        <rect x="86"  y="152" width="116" height="7" rx="3" class="c-accent"/>

        <!-- line 6 -->
        <rect x="74"  y="169" width="9"  height="7" rx="2" class="c-dim"/>
        <rect x="88"  y="169" width="30" height="7" rx="3" class="c-muted"/>

        <!-- output line (green) -->
        <rect x="74"  y="186" width="78" height="7" rx="3" class="c-ok"/>

        <!-- cursor -->
        <rect x="74"  y="202" width="3"  height="13" rx="1" class="cursor-blink"/>

        <!-- ── Monitor stand ──────────────────────────────── -->
        <line x1="186" y1="240" x2="186" y2="264" class="stand"/>
        <rect x="158"  y="264" width="56"  height="6"  rx="3" class="stand-base"/>
      </svg>
    </div>

  </div>
</section>

<script>
  // Measure actual path length for smooth stroke animation
  const path = document.querySelector<SVGPathElement>('.logo-path');
  if (path) {
    const len = path.getTotalLength();
    path.style.setProperty('--path-len', String(len));
  }
</script>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
  }

  /* Two-column layout */
  .hero-layout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-12);
  }

  .hero-text {
    flex: 1 1 0;
    min-width: 0;
  }

  .hero-greeting {
    font-size: var(--text-base);
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: var(--space-3);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Brand lockup (logo + name) ────────────────────────── */
  .brand-lockup {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    cursor: default;
  }

  .logo-mark {
    flex-shrink: 0;
    width: clamp(52px, 7vw, 72px);
    height: auto;
    overflow: visible;
    display: block;
  }

  .logo-path {
    fill: rgba(108, 126, 255, 0.07);
    stroke: var(--accent);
    stroke-width: 6;
    stroke-linejoin: round;
    stroke-linecap: round;
    stroke-dasharray:  var(--path-len, 5500);
    stroke-dashoffset: var(--path-len, 5500);
    transition:
      stroke-dashoffset var(--t-speed-slow) var(--t-ease-out),
      fill              var(--t-slow),
      stroke            var(--t-base);
  }

  .brand-lockup:hover .logo-path {
    stroke-dashoffset: 0;
    fill: rgba(108, 126, 255, 0.14);
    stroke: var(--accent-hover);
  }

  .hero-name {
    font-size: clamp(var(--text-3xl), 5.5vw, var(--text-5xl));
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text);
    margin: 0;
  }

  .hero-title {
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    max-width: 480px;
    color: var(--text-muted);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-10);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Developer illustration ─────────────────────────────── */
  .dev-illo-wrap {
    flex-shrink: 0;
    width: clamp(200px, 32vw, 440px);   /* grows up to 440px on wide screens */
  }

  .dev-illo {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* Node graph */
  .nd  { fill: var(--accent); opacity: 0.25; }
  .nl  { stroke: var(--accent); stroke-width: 0.8; opacity: 0.12; }

  /* Floating symbols */
  .br  { stroke: var(--accent); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; opacity: 0.55; }
  .float-a { animation: floatA 5s ease-in-out infinite; }
  .float-b { animation: floatB 6s ease-in-out infinite; }

  @keyframes floatA {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-7px); }
  }
  @keyframes floatB {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(5px); }
  }

  /* Terminal window */
  .win-frame  { stroke: var(--border); stroke-width: 1.5; }
  .win-bar    { fill: rgba(255,255,255,0.04); }
  .tab-pill   { fill: rgba(108,126,255,0.12); }

  .dot-r  { fill: rgba(255,94,86,0.55); }
  .dot-y  { fill: rgba(255,188,46,0.45); }
  .dot-g  { fill: rgba(40,200,100,0.45); }

  /* Code line colours */
  .c-accent  { fill: var(--accent);       opacity: 0.75; }
  .c-accent2 { fill: var(--accent-hover); opacity: 0.6;  }
  .c-muted   { fill: var(--text-faint);   opacity: 0.35; }
  .c-dim     { fill: var(--text-faint);   opacity: 0.2;  }
  .c-ok      { fill: #40c980;             opacity: 0.55; }

  /* Blinking cursor */
  .cursor-blink {
    fill: var(--accent);
    opacity: 0.9;
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 0.9; }
    50%       { opacity: 0;   }
  }

  /* Monitor stand */
  .stand      { stroke: var(--border); stroke-width: 1.5; stroke-linecap: round; }
  .stand-base { stroke: var(--border); stroke-width: 1.5; }

  /* ── Buttons ─────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    padding: 0.65em 1.5em;
    border-radius: var(--radius-sm);
    transition:
      color        var(--t-base),
      background   var(--t-base),
      border-color var(--t-base),
      opacity      var(--t-base),
      transform    var(--t-fast);
  }

  .btn:hover  { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
  }

  .btn-ghost {
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover {
    color: var(--text);
    border-color: var(--text-faint);
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-layout {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-10);
    }

    .dev-illo-wrap {
      width: clamp(200px, 70vw, 360px);
      align-self: center;
    }
  }
</style>

