---
import NavLogo from './nav/NavLogo.astro';
import ThemeToggle from './nav/ThemeToggle.astro';
import LanguageSwitcher from './nav/LanguageSwitcher.astro';
import { useTranslations } from '../i18n';

const T = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale ?? 'en';

const links = [
  { label: T.nav.about,      href: `/${locale}/#about`      },
  { label: T.nav.experience, href: `/${locale}/#experience` },
  { label: T.nav.skills,     href: `/${locale}/#skills`     },
  { label: T.nav.contact,    href: `/${locale}/#contact`    },
  { label: T.nav.blog,       href: `/${locale}/blog`        },
];
---

<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <NavLogo />

    <ul class="nav-links" role="list">
      {links.map((l) => (
        <li>
          <a href={l.href} class="nav-link">{l.label}</a>
        </li>
      ))}
    </ul>

    <div class="nav-controls">
      <LanguageSwitcher />
    </div>

    <ThemeToggle />

    <button class="nav-toggle" id="nav-toggle" aria-label={T.nav.toggleMenu} aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <span class="nav-indicator" aria-hidden="true"></span>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul class="mobile-links" role="list">
      {links.map((l) => (
        <li>
          <a href={l.href} class="mobile-link">{l.label}</a>
        </li>
      ))}
    </ul>
    <div class="mobile-lang">
      <LanguageSwitcher />
    </div>
  </div>
</nav>

<script>
  import { initNav, initThemeToggle } from '../scripts/nav';
  initNav();
  initThemeToggle();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    z-index: 100;
    transition: background var(--t-base), border-color var(--t-base), height var(--t-base);
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    height: 44px;
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--border);
  }

  .nav-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--content-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
  }

  .nav-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    border-radius: var(--radius-full);
    opacity: 0;
    pointer-events: none;
    transition:
      left    200ms cubic-bezier(0.4, 0, 0.2, 1),
      width   200ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 150ms ease;
  }

  @media (min-width: 640px)  { .nav-inner { padding-inline: var(--space-6);  } }
  @media (min-width: 1024px) { .nav-inner { padding-inline: var(--space-10); } }
  @media (min-width: 1280px) { .nav-inner { padding-inline: var(--space-12); } }

  /* Desktop links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
    letter-spacing: var(--tracking-wide);
    transition: color var(--t-base);
  }
  .nav-link:hover { color: var(--text); }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
  }

  .bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--text-muted);
    border-radius: var(--radius-full);
    transition: transform var(--t-base), opacity var(--t-base), background var(--t-base);
  }

  .nav-toggle.open .bar:first-child {
    transform: translateY(6.5px) rotate(45deg);
    background: var(--text);
  }
  .nav-toggle.open .bar:last-child {
    transform: translateY(-6.5px) rotate(-45deg);
    background: var(--text);
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    background: var(--nav-mobile-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--border);
    overflow: hidden;
    max-height: 0;
    transition: max-height var(--t-slow);
  }

  .mobile-menu.open { max-height: 420px; }

  .mobile-links {
    padding: var(--space-4) var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .mobile-link {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
    padding-block: var(--space-3);
    display: block;
    transition: color var(--t-base);
  }
  .mobile-link:hover { color: var(--text); }

  @media (max-width: 640px) {
    .nav-links    { display: none; }
    .nav-controls { display: none; }
    .nav-toggle   { display: flex; }
    .mobile-menu  { display: block; }
  }

  .mobile-lang {
    padding: var(--space-4) var(--space-6) var(--space-5);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
</style>
