---
import { skillGroups } from '../data/skills';
import { useTranslations } from '../i18n';

const T = useTranslations(Astro.currentLocale);

const categoryIcons: Record<string, string> = {
  'Frameworks':           `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="6" height="6" rx="1.5"/><rect x="12" y="2" width="6" height="6" rx="1.5"/><rect x="2" y="12" width="6" height="6" rx="1.5"/><circle cx="15" cy="15" r="3"/></svg>`,
  'Languages':            `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6,5 2,10 6,15"/><polyline points="14,5 18,10 14,15"/><line x1="11" y1="3" x2="9" y2="17"/></svg>`,
  'AI / ML':              `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="2.5"/><circle cx="4" cy="5" r="1.5"/><circle cx="16" cy="5" r="1.5"/><circle cx="4" cy="15" r="1.5"/><circle cx="16" cy="15" r="1.5"/><line x1="5.5" y1="6" x2="8.5" y2="8.5"/><line x1="14.5" y1="6" x2="11.5" y2="8.5"/><line x1="5.5" y1="14" x2="8.5" y2="11.5"/><line x1="14.5" y1="14" x2="11.5" y2="11.5"/></svg>`,
  'Cloud & DevOps':       `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 13a4 4 0 0 0-3.5-7 5.5 5.5 0 0 0-10 3.5A3.5 3.5 0 0 0 5 13Z"/><polyline points="10,13 10,17"/><polyline points="7,15 10,17 13,15"/></svg>`,
  'Databases':            `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="10" cy="6" rx="7" ry="2.5"/><path d="M3 6v4c0 1.38 3.13 2.5 7 2.5s7-1.12 7-2.5V6"/><path d="M3 10v4c0 1.38 3.13 2.5 7 2.5s7-1.12 7-2.5v-4"/></svg>`,
  'Process & Leadership': `<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="6" r="2.5"/><circle cx="13" cy="6" r="2.5"/><path d="M2 17c0-2.76 2.24-5 5-5h6c2.76 0 5 2.24 5 5"/></svg>`,
};
---

<section class="section" id="skills">
  <div class="container">
    <span class="section-label">{T.skills.label}</span>
    <h2 class="section-title">{T.skills.title}</h2>

    <div class="skill-rows">
      {skillGroups.map((group, gi) => (
        <div class="skill-row" style={`--gi:${gi}`}>
          <div class="row-label">
            <span
              class="row-icon"
              aria-hidden="true"
              set:html={categoryIcons[group.category]}
            />
            <span class="row-name">{T.skills.categories[group.category] ?? group.category}</span>
          </div>
          <ul class="chip-list">
            {group.items.map((skill) => (
              <li class={`chip${skill.level ? ' chip--adv' : ''}`}>
                {skill.level && <span class="adv-dot" aria-hidden="true" />}
                {skill.name}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="skills-note">
      <span class="adv-dot" aria-hidden="true" />
      <span>{T.skills.advancedNote}</span>
    </p>
  </div>
</section>

<script>
  const rows = document.querySelectorAll<HTMLElement>('.skill-row');
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  rows.forEach((r) => obs.observe(r));
</script>

<style>
  /* ── Rows container ──────────────────────────────────────── */
  .skill-rows {
    margin-top: var(--space-10);
    border-top: 1px solid var(--border);
  }

  /* ── Single row ──────────────────────────────────────────── */
  .skill-row {
    display: grid;
    grid-template-columns: 176px 1fr;
    gap: var(--space-8);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--border);

    /* scroll-reveal: slide in from left */
    opacity: 0;
    transform: translateX(-16px);
    transition:
      opacity   360ms var(--t-ease) calc(var(--gi, 0) * 65ms),
      transform 360ms var(--t-ease) calc(var(--gi, 0) * 65ms);
  }

  .skill-row.visible {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-row { opacity: 1; transform: none; transition: none; }
  }

  @media (max-width: 600px) {
    .skill-row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }

  /* ── Category label column ───────────────────────────────── */
  .row-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: 3px; /* optical baseline alignment */
  }

  .row-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    background: var(--accent-dim);
    color: var(--accent);
  }

  .row-icon :global(svg) {
    width: 14px;
    height: 14px;
  }

  .row-name {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--text-muted);
    font-weight: var(--weight-medium);
    white-space: nowrap;
  }

  /* ── Chip list ───────────────────────────────────────────── */
  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-content: flex-start;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    padding: 4px 10px;
    line-height: 1;
    transition:
      color        var(--t-fast),
      border-color var(--t-fast),
      background   var(--t-fast);
  }

  .chip:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    background: var(--accent-dim);
  }

  /* Advanced variant — accent-tinted border + fill */
  .chip--adv {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .chip--adv:hover {
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }

  /* Dot indicator for Advanced skills */
  .adv-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* ── Legend ──────────────────────────────────────────────── */
  .skills-note {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-faint);
  }
</style>
