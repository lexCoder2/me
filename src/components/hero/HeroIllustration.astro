    <rect x="46"  y="263" width="6"  height="5" rx="1" class="stat-l"/>
    <rect x="56"  y="263" width="20" height="5" rx="1" class="stat-l"/>
    <rect x="234" y="263" width="24" height="5" rx="1" class="stat-r"/>
    <rect x="264" y="263" width="16" height="5" rx="1" class="stat-r"/>
    <rect x="286" y="263" width="24" height="5" rx="1" class="stat-r"/>
