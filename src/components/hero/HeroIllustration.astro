</div>

<style>
  .dev-illo-wrap {
    flex-shrink: 0;
    width: clamp(200px, 32vw, 440px);
  }

  .dev-illo {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* Node graph */
  .nd  { fill: var(--accent); opacity: 0.25; }
  .nl  { stroke: var(--accent); stroke-width: 0.8; opacity: 0.12; }

  /* Floating symbols */
  .br  { stroke: var(--accent); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; opacity: 0.55; }
  .float-a { animation: floatA 5s ease-in-out infinite; }
  .float-b { animation: floatB 6s ease-in-out infinite; }
  .float-c { animation: floatC 4.5s ease-in-out infinite; }

  @keyframes floatA {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-7px); }
  }
  @keyframes floatB {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(5px); }
  }
  @keyframes floatC {
    0%, 100% { transform: translateX(0px); }
    50%       { transform: translateX(5px); }
  }

  /* Editor window */
  .win-frame  { stroke: var(--border); stroke-width: 1.5; }
  .win-bar    { fill: var(--bg-alt); }
  .tab-pill   { fill: var(--accent-dim); }
  .tab-x      { stroke: var(--text-faint); stroke-width: 1.5; stroke-linecap: round; opacity: 0.4; }
  .win-glow   { fill: var(--accent); opacity: 0.05; }

  .sidebar    { fill: var(--bg-alt); opacity: 0.6; }
  .icon-act   { fill: var(--accent); opacity: 0.7; }
  .icon       { fill: var(--text-faint); opacity: 0.2; }
  .gutter     { fill: var(--bg-alt); opacity: 0.4; }
  .ln         { fill: var(--text-faint); opacity: 0.18; }
  .line-hl    { fill: var(--accent); opacity: 0.1; }

  .dot-r  { fill: rgba(255,94,86,0.55); }
  .dot-y  { fill: rgba(255,188,46,0.45); }
  .dot-g  { fill: rgba(40,200,100,0.45); }

  .c-accent  { fill: var(--accent);       opacity: 0.75; }
  .c-accent2 { fill: var(--accent-hover); opacity: 0.6;  }
  .c-muted   { fill: var(--text-faint);   opacity: 0.35; }
  .c-dim     { fill: var(--text-faint);   opacity: 0.2;  }
  .c-ok      { fill: #40c980;             opacity: 0.55; }

  .cursor-blink {
    fill: var(--accent);
    opacity: 0.9;
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 0.9; }
    50%       { opacity: 0;   }
  }

  .term-sep   { stroke: var(--border); stroke-width: 1; }
  .term-bg    { fill: var(--bg); opacity: 0.5; }
  .term-title { fill: var(--bg-alt); opacity: 0.8; }
  .term-label { fill: var(--accent); opacity: 0.45; }
  .status-bar { fill: var(--accent); opacity: 0.14; }
  .stat-l     { fill: #fff; opacity: 0.5; }
  .stat-r     { fill: #fff; opacity: 0.35; }

  @media (max-width: 900px) {
    .dev-illo-wrap {
      width: clamp(200px, 70vw, 360px);
      align-self: center;
    }
  }
</style>
