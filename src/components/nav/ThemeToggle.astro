---
---

<button class="theme-toggle" id="theme-btn" aria-label="Toggle color theme">
  <span class="tt-track" aria-hidden="true">
    <span class="tt-knob"></span>
  </span>
  <!-- Sun icon -->
  <svg class="tt-icon tt-sun" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1"  x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22"  y1="4.22"  x2="5.64"  y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1"  y1="12" x2="3"  y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22"  y1="19.78" x2="5.64"  y2="18.36"/>
    <line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon -->
  <svg class="tt-icon tt-moon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 4px 8px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--bg-alt);
    cursor: pointer;
    color: var(--text-muted);
    transition:
      border-color var(--t-base),
      background   var(--t-base),
      color        var(--t-base);
  }
  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Track + knob */
  .tt-track {
    display: inline-flex;
    align-items: center;
    width: 28px;
    height: 16px;
    border-radius: var(--radius-full);
    background: var(--accent-dim);
    position: relative;
    transition: background var(--t-base);
  }
  .tt-knob {
    position: absolute;
    left: 2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    transition: transform var(--t-base), background var(--t-base);
  }
  [data-theme="light"] .tt-knob { transform: translateX(12px); }

  /* Icon visibility */
  .tt-icon { display: block; }
  .tt-sun  { opacity: 0.5; }
  .tt-moon { opacity: 0.5; }

  [data-theme="dark"]  .tt-moon { opacity: 1; }
  [data-theme="light"] .tt-sun  { opacity: 1; }
  [data-theme="dark"]  .tt-sun  { opacity: 0.3; }
  [data-theme="light"] .tt-moon { opacity: 0.3; }
</style>
