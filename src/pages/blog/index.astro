---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Blog"
  description="Articles on full-stack development, AI/LLM engineering, distributed systems, and lessons from working with some of the world's largest tech teams."
>
  <div class="container blog-index section">
    <span class="section-label">Writing</span>
    <h1 class="section-title">Blog</h1>
    <p class="blog-intro">
      Notes, opinions, and deep-dives from over 10 years on the stack.
      I write about what I'm actually building — not what sounds good in theory.
    </p>

    {allPosts.length === 0 ? (
      <p class="empty">No posts yet. Check back soon.</p>
    ) : (
      <div class="post-list">
        {allPosts.map((post) => <BlogCard post={post} />)}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .blog-index {
    padding-top: calc(var(--nav-height) + var(--space-16));
  }

  .blog-intro {
    font-size: var(--text-base);
    color: var(--text-muted);
    max-width: 520px;
    line-height: var(--leading-loose);
    margin-bottom: var(--space-12);
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }

  .empty {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-faint);
  }
</style>
