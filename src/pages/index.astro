---
// Root redirect to default locale. Astro requires this file to exist when
// using i18n with redirectToDefaultLocale: true, but also overrides it with
// a higher-priority route — so we provide the explicit redirect ourselves.
const locale = 'en';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=/${locale}/`} />
    <link rel="canonical" href={`/${locale}/`} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={`/${locale}/`}>/{locale}/</a></p>
  </body>
</html>
